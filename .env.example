# RallyOS Hub Environment Configuration
# Copy this file to .env and adjust values as needed

# Node environment (development or production)
NODE_ENV=production

# Application port
PORT=3000

# Tournament Owner PIN for admin access (8 digits)
TOURNAMENT_OWNER_PIN=12345678

# Wi-Fi SSID that the hub will broadcast (if enabled)
HUB_SSID=RallyOS

# Hub IP address for network configuration
HUB_IP=192.168.4.1

# Hub domain name (used for CORS, SSL certs, host validation, and display URLs)
HUB_DOMAIN=rallyos-hub.local

# Wi-Fi password for the hub's access point (shown in QR code on scoreboard)
HUB_WIFI_PASSWORD=rallyos2026

# ⚠️  CORS ALLOWED ORIGINS — edit only if you know what you're doing
# When set, this OVERRIDES all default origins. The defaults include:
# localhost:3000, localhost:5173, 127.0.0.1:3000, orangepi.local:3000,
# rallyos.local:3000, and the HUB_DOMAIN (rallyos-hub.local:3000).
# If you set this, you MUST include ALL origins you need.
# Leave commented/empty to use the safe defaults.
# HUB_ALLOWED_ORIGINS=https://localhost:3000,https://192.168.4.1:3000,https://rallyos-hub.local:3000

# Node.js memory limit (for Orange Pi and limited RAM devices)
NODE_OPTIONS=--max-old-space-size=256

# Encryption secret for AES-256-GCM PIN encryption (server-side only)
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=
