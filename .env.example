# RallyOS Hub Environment Configuration
# Copy this file to .env and adjust values as needed

# Node environment (development or production)
NODE_ENV=production

# Application port
PORT=3000

# Tournament Owner PIN for admin access (8 digits)
TOURNAMENT_OWNER_PIN=12345678

# Wi-Fi SSID that the hub will broadcast (if enabled)
HUB_SSID=RallyOS

# Hub IP address for network configuration
HUB_IP=192.168.4.1

# Node.js memory limit (for Orange Pi and limited RAM devices)
NODE_OPTIONS=--max-old-space-size=256

# Encryption secret for AES-256-GCM PIN encryption (must match client's VITE_ENCRYPTION_SECRET)
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=
