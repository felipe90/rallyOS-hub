# Dashboard polling interval (in milliseconds)
# Default: 3000ms (3 seconds)
# Set to 0 to disable polling (rely on socket push updates)
VITE_TABLE_REFRESH_MS=3000
# Encryption secret for AES-256-GCM PIN encryption (must match server's ENCRYPTION_SECRET)
# Generate with: openssl rand -hex 32
VITE_ENCRYPTION_SECRET=
