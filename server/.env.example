# Pin de seguridad para el Hub
REFEREE_PIN=12345

# Entorno (development | production)
NODE_ENV=development

# Comma-separated CORS allowlist for Hub web clients
# Leave empty to use defaults:
# http://localhost:3000,http://127.0.0.1:3000,http://orangepi.local:3000
HUB_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://orangepi.local:3000
