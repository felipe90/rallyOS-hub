# rallyOS-hub Environment Configuration
# Copy this file to .env and configure as needed

# Server port
PORT=3000

# Node environment
NODE_ENV=production

# Tournament Owner PIN (5-8 digits, required for admin access)
# If not set, a random 8-digit PIN will be generated at startup
TOURNAMENT_OWNER_PIN=

# Encryption secret for PIN encryption (optional, 32+ chars recommended)
# If not set, a random secret will be generated at startup
ENCRYPTION_SECRET=

# Hub SSID (WiFi network name shown to clients)
HUB_SSID=RallyOS

# Hub IP address (shown in QR codes)
HUB_IP=192.168.4.1

# Allowed CORS origins (comma-separated)
# Leave empty to use default allowed origins
HUB_ALLOWED_ORIGINS=

# Log level (debug, info, warn, error)
LOG_LEVEL=info
